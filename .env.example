# Discord Bot Token
# Get from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Telegram Bot Token
# Get from: @BotFather on Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Telegram API 代理（可选，国内服务器需要）
# 设置后会通过代理连接 api.telegram.org
# HTTPS_PROXY=http://127.0.0.1:7890
# 或者使用自定义 API Root:
# TELEGRAM_API_ROOT=https://your-proxy-host.com

# Twitter/X Authentication
# Option 1: Cookie-based (recommended, extract from browser)
TWITTER_AUTH_TOKEN=your_auth_token_here
TWITTER_CT0=your_ct0_here

# Option 2: Username/password (used for initial login to obtain cookies)
# TWITTER_USERNAME=your_username
# TWITTER_PASSWORD=your_password
# TWITTER_EMAIL=your_email@example.com
# TWITTER_TOTP_SECRET=your_totp_base32_secret

# X to Image API (optional, uses external service to render tweet images)
# X_TO_IMAGE_API_URL=https://your-x-to-image-worker.dev
# X_TO_IMAGE_API_TOKEN=your_api_token
# X_TO_IMAGE_API_THEME=dark

# AI Chat (optional, overrides config file ai.*)
# AI_API_URL=https://api.openai.com/v1
# AI_API_KEY=your_api_key
# Web search provider key (tavily / serper / brave)
# AI_WEB_SEARCH_API_KEY=your_search_api_key
