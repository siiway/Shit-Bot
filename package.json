{
  "name": "shit-bot",
  "version": "1.0.0",
  "description": "Monitor X/Twitter users and forward posts to Discord/Telegram",
  "main": "dist/index.js",
  "packageManager": "bun",
  "scripts": {
    "build": "tsc && cp src/web/ui.html dist/web/ui.html",
    "start": "node dist/index.js",
