    "deploy": "bunx hugo && wrangler deploy",
    "preview": "bunx hugo && wrangler dev"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "discord.js": "^14.14.1",
    "dotenv": "^16.3.1",
    "https-proxy-agent": "^9.0.0",
    "node-cron": "^3.0.3",
    "rss-parser": "^3.13.0",
    "smol-toml": "^1.6.1",
    "speakeasy": "^2.0.0",
    "telegraf": "^4.16.3",
    "twitter-openapi-typescript": "^0.0.56",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.5",
    "@types/node-cron": "^3.0.11",
    "@types/speakeasy": "^2.0.10",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "wrangler": "^4.98.0"
  }
